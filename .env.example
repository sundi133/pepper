# Database
DATABASE_URL="postgresql://pepper:pepper_dev@localhost:5432/pepper"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO / S3
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_USE_SSL="false"
MINIO_BUCKET="pepper-artifacts"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional: public URL shown as "Source" / "View project source" on the login page
# NEXT_PUBLIC_SOURCE_CODE_URL="https://github.com/your-org/pepper"

# Optional: GitHub OAuth (NextAuth login and/or repository connection)
# GITHUB_ID=""
# GITHUB_SECRET=""
# Dedicated OAuth app for "Connect GitHub Repository" (falls back to GITHUB_ID / GITHUB_SECRET)
# Register callback: {NEXTAUTH_URL}/api/integrations/github/callback
# GITHUB_OAUTH_CLIENT_ID=""
# GITHUB_OAUTH_CLIENT_SECRET=""
# Optional: separate key for encrypting stored tokens (defaults to NEXTAUTH_SECRET)
# TOKEN_ENCRYPTION_KEY=""
# GITHUB_WEBHOOK_SECRET=""

# Optional: Bitbucket Cloud webhook signing secret. When set, Pepper verifies
# the X-Hub-Signature header on /api/webhooks/bitbucket. The per-org
# Bitbucket app password is configured via the Integrations UI
# (POST /api/integrations/bitbucket/connect) — no env var needed for that.
# BITBUCKET_WEBHOOK_SECRET=""

# Open fix PR uses the GitHub OAuth token from Repositories (no PAT required).
# Legacy optional PAT (not used if OAuth is connected):
# GITHUB_PR_TOKEN=""
# GITHUB_TOKEN=""

# Optional: GitLab OAuth
# GITLAB_ID=""
# GITLAB_SECRET=""
# GITLAB_URL="https://gitlab.com"

# OpenRouter (alternative to Ollama — access 100+ cloud models)
# Get your key at https://openrouter.ai/keys
# OPENROUTER_API_KEY=""
# OPENROUTER_MODEL="google/gemini-2.5-flash"

# DAST / Dapper orchestration
# Local Pepper scans can bootstrap a sibling ../dapper checkout automatically.
# Override the workspace root if you want Pepper to use a specific Dapper repo.
# DAPPER_WORKSPACE_DIR=""
# DAPPER_REPO_URL="https://github.com/sundi133/dapper.git"
# DAPPER_CONFIG_PATH=""
# DAPPER_EXPORT_MODEL="claude-opus-4-6"
# DAPPER_EXPORT_MAX_TURNS="100"
# DAPPER_ROUTER="false"
# DAPPER_PIPELINE_TESTING="false"

# Worker
WORKER_CONCURRENCY="2"
MAX_LLM_CONCURRENCY="5"

# LLM SAST Context Configuration
# Chunk tokens = how much code is sent per LLM request (estimated tokens)
# Response tokens = max tokens the LLM can generate in its response
# Overlap tokens = context overlap between consecutive chunks
# LLM_CHUNK_TOKENS="3000"              # API models (OpenAI, etc.)
# LLM_CHUNK_OVERLAP_TOKENS="200"
# LLM_MAX_RESPONSE_TOKENS="4096"
# OLLAMA_CHUNK_TOKENS="1200"           # Local Ollama models
# OLLAMA_CHUNK_OVERLAP_TOKENS="100"
# OLLAMA_MAX_RESPONSE_TOKENS="2048"
# LLM_MIN_CONFIDENCE="0.7"            # Drop findings below this confidence

# Email Notifications (optional — SMTP)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@pepper-sast.local"
# SMTP_TLS="true"
# Team invites for brand-new users include the initial password in email when
# SMTP is enabled—use a test sink (Mailpit) or trusted mail; not for public SMTP.

# Default Admin (used by seed script)
ADMIN_EMAIL="admin@pepper.local"
ADMIN_PASSWORD="pepper-admin-changeme"
