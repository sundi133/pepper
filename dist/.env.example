# ──────────────────────────────────────────────────────────────────────
# Pepper SAST — Configuration
# Copy this file to .env and fill in the required values
# ──────────────────────────────────────────────────────────────────────

# ─── Required ─────────────────────────────────────────────────────────

# Database password (pick a strong random password)
POSTGRES_PASSWORD="CHANGE_ME_strong_random_password"

# NextAuth session secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="CHANGE_ME_random_secret"

# Admin account created on first startup
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="CHANGE_ME_admin_password"

# ─── Optional ─────────────────────────────────────────────────────────

# Public URL where Pepper is accessible (for OAuth callbacks etc.)
# NEXTAUTH_URL="https://pepper.yourcompany.com"

# Port to expose on the host (default 3000)
# PEPPER_PORT=3000

# Ollama host for AI-powered scanning (must be reachable from Docker)
# On macOS/Windows Docker Desktop: http://host.docker.internal:11434
# On Linux: http://172.17.0.1:11434  (or your host IP)
OLLAMA_HOST="http://host.docker.internal:11434"

# MinIO / S3 credentials (defaults work for bundled MinIO)
# MINIO_ACCESS_KEY="minioadmin"
# MINIO_SECRET_KEY="minioadmin"

# Worker tuning
# WORKER_CONCURRENCY=2      # parallel scan jobs
# MAX_LLM_CONCURRENCY=1     # parallel LLM requests per scan (keep 1 for CPU)
# WORKER_REPLICAS=1          # number of worker containers

# Image override (for private registries)
# PEPPER_IMAGE="your-registry.com/pepper"
# PEPPER_VERSION="1.2.0"

# ─── OAuth Providers (optional) ──────────────────────────────────────

# GitHub OAuth
# GITHUB_ID=""
# GITHUB_SECRET=""

# GitLab OAuth
# GITLAB_ID=""
# GITLAB_SECRET=""
# GITLAB_URL="https://gitlab.com"
