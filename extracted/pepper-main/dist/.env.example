# Pepper SAST - Customer Configuration
# Copy this file to .env and fill in the required values.

# Required
POSTGRES_PASSWORD="CHANGE_ME_strong_random_password"
NEXTAUTH_SECRET="CHANGE_ME_random_secret"
ADMIN_EMAIL="admin@yourcompany.com"
ADMIN_PASSWORD="CHANGE_ME_admin_password"

# Default AI provider: OpenRouter
LLM_PROVIDER="openrouter"
LLM_BASE_URL="https://openrouter.ai/api/v1"
LLM_MODEL="google/gemini-2.5-flash"
LLM_API_KEY="CHANGE_ME_openrouter_api_key"

# Optional public URL and port
# NEXTAUTH_URL="https://pepper.yourcompany.com"
# PEPPER_PORT=3000

# Optional OpenRouter metadata
# OPENROUTER_REFERER="https://pepper.yourcompany.com"
# OPENROUTER_TITLE="Pepper SAST"

# Optional Ollama fallback. Only used when LLM_PROVIDER="ollama".
# OLLAMA_HOST="http://host.docker.internal:11434"

# Optional bundled MinIO credentials
# MINIO_ACCESS_KEY="minioadmin"
# MINIO_SECRET_KEY="CHANGE_ME_minio_password"

# Worker tuning
# WORKER_CONCURRENCY=2
# MAX_LLM_CONCURRENCY=2
# WORKER_REPLICAS=1

# Private registry images
# PEPPER_API_IMAGE="registry.example.com/pepper"
# PEPPER_WORKER_IMAGE="registry.example.com/pepper-worker"
# PEPPER_VERSION="1.2.0"

# Optional registry auth values used by setup.sh
# PEPPER_REGISTRY="registry.example.com"
# PEPPER_REGISTRY_USERNAME=""
# PEPPER_REGISTRY_PASSWORD=""

# Optional OAuth providers
# GITHUB_ID=""
# GITHUB_SECRET=""
# GITLAB_ID=""
# GITLAB_SECRET=""
# GITLAB_URL="https://gitlab.com"
