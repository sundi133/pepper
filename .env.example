# Database
DATABASE_URL="postgresql://pepper:pepper_dev@localhost:5432/pepper"

# Redis
REDIS_URL="redis://localhost:6379"

# MinIO / S3
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_USE_SSL="false"
MINIO_BUCKET="pepper-artifacts"

# NextAuth
NEXTAUTH_SECRET="change-me-to-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional: GitHub OAuth
# GITHUB_ID=""
# GITHUB_SECRET=""

# Optional: GitLab OAuth
# GITLAB_ID=""
# GITLAB_SECRET=""
# GITLAB_URL="https://gitlab.com"

# Worker
WORKER_CONCURRENCY="2"
MAX_LLM_CONCURRENCY="5"

# Default Admin (used by seed script)
ADMIN_EMAIL="admin@pepper.local"
ADMIN_PASSWORD="pepper-admin-changeme"
